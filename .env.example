# expense-service environment overrides. Copy to .env (gitignored) and source it,
# or rely on the env-specific JSON under assets/kharchibook. Every key maps to a
# config field via Viper: nested config.store.host ⇄ STORE_HOST, etc.

# Active environment selects assets/kharchibook/<env>-config.json
ACTIVE_ENV=dev

# Postgres (a SEPARATE database from auth-service)
STORE_HOST=localhost
STORE_PORT=5433
STORE_USER=expense
STORE_PASSWORD=expense
STORE_NAME=expense_service
STORE_SSLMODE=disable

# Redis — SHARED with auth-service. Use a distinct DB index to isolate keys.
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_PASSWORD=
CACHE_DB=1
CACHE_TLS=false

# JWT verification — only the PUBLIC key of the auth-service signing keypair.
# Either a file path or the inline PEM. The dev config points at assets/keys.
TOKEN_PUBLICKEYPATH=assets/keys/jwt_public.pem
# TOKEN_PUBLICKEYPEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
